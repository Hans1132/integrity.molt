# integrity.molt x402 server — konfigurace
# Zkopírovat jako .env a vyplnit hodnoty

# Port, na kterém server naslouchá (za NGINX proxy)
PORT=3402

# Solana wallet adresa, na kterou přicházejí USDC platby
# POVINNÉ — server odmítne start bez této hodnoty
SOLANA_WALLET_ADDRESS=

# Solana RPC endpoint
# Výchozí veřejný endpoint NENÍ pro produkci (rate-limiting, bez záruky dostupnosti)
# Doporučeno: Helius (https://helius.dev) nebo QuickNode
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# PostgreSQL connection string
# Schema se vytvoří automaticky při prvním startu
DATABASE_URL=postgresql://intmolt:HESLO@localhost/intmolt

# Token pro přístup k /stats/funnel (Bearer token)
# Vygenerovat: openssl rand -hex 24
STATS_TOKEN=

# Stripe (subscription checkout)
# Dashboard: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs: Dashboard → Products → vytvořit Builder ($79/mo) a Team ($299/mo)
STRIPE_PRICE_BUILDER=price_...
STRIPE_PRICE_TEAM=price_...

# Veřejná URL aplikace (pro Stripe redirect)
APP_URL=https://intmolt.org

# Telegram bot token (pro watchlist alerty)
# Vytvořit: @BotFather na Telegramu → /newbot
TELEGRAM_BOT_TOKEN=

# Mailgun API (volitelné — pro email alerty)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# AutoPilot co-signing rules (A2A autonomous agent transactions)
AUTOPILOT_ENABLED=true
AUTOPILOT_MAX_TX_USDC=5.0
AUTOPILOT_MAX_DAILY_USDC=50.0
AUTOPILOT_ALLOWED_SKILLS=quick_scan,token_audit,agent_token_scan,wallet_profile
AUTOPILOT_BLACKLIST=
